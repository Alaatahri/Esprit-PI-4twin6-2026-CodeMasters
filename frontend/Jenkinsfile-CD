pipeline {
  agent any

  stages {
    stage('Pull Latest Image') {
      steps {
        sh 'docker pull jedidisy/bmp-frontend:latest'
      }
    }

    stage('Stop Old Container') {
      steps {
        sh 'docker stop bmp-frontend || true'
        sh 'docker rm bmp-frontend || true'
      }
    }

    stage('Deploy') {
      steps {
        sh 'docker run -d --name bmp-frontend -p 3101:3000 jedidisy/bmp-frontend:latest'
      }
    }

    stage('Health Check') {
      steps {
        sh 'sleep 5 && docker ps | grep bmp-frontend'
      }
    }
  }

  post {
    success {
      echo 'Frontend deployed successfully!'
    }
    failure {
      sh 'docker logs bmp-frontend || true'
    }
  }
}
