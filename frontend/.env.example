# Copier vers .env.local (non versionné)
#
# Proxy Next.js : /api/* → backend (voir next.config.ts)
BACKEND_ORIGIN=http://127.0.0.1:3001

# Optionnel : appeler l’API en URL absolue (prod ou sans rewrite)
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3001/api

# --- Production (ex. front Vercel + API Railway) ---
# URL publique HTTPS du service Nest, sans slash final (rewrites : /api → ce host).
# BACKEND_ORIGIN=https://xxxx.up.railway.app
# Ou si l’API est sous un sous-chemin Vercel Services : BACKEND_ORIGIN=https://ton-site.vercel.app/_/backend
# Côté backend : MONGODB_URI, CORS_ORIGINS (même URL que le site Next), FRONTEND_URL pour les mails.
# NEXT_PUBLIC_API_URL=https://xxxx.up.railway.app/api
