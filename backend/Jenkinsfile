pipeline {
  agent any

  tools {
    nodejs 'NodeJS-18'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install Dependencies') {
      steps {
        dir('backend') {
          sh 'npm ci'
        }
      }
    }

    stage('Tests with Coverage') {
      steps {
        dir('backend') {
          sh 'npm test -- --coverage --forceExit || true'
        }
      }
    }

    stage('SonarQube Analysis') {
      steps {
        withSonarQubeEnv('SonarQube') {
          dir('backend') {
            sh '''
              npx sonar-scanner \
                -Dsonar.projectKey=bmp-backend \
                -Dsonar.sources=src \
                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                -Dsonar.testExecutionReportPaths=coverage/test-reporter.xml \
                -Dsonar.host.url=http://192.168.106.1:9000 \
                -Dsonar.token=${SONAR_AUTH_TOKEN}
            '''
          }
        }
      }
    }

    stage('Run Tests') {
      steps {
        dir('backend') {
          sh 'npm test -- --passWithNoTests --forceExit || true'
        }
      }
    }

    stage('Build') {
      steps {
        dir('backend') {
          sh 'npm run build'
        }
      }
    }

    stage('Docker Build & Push') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKERHUB_USERNAME', passwordVariable: 'DOCKERHUB_PASSWORD')]) {
          sh '''
            set -e
            echo "$DOCKERHUB_PASSWORD" | docker login -u "$DOCKERHUB_USERNAME" --password-stdin
            docker build -t jedidisy/bmp-backend:latest ./backend
            docker push jedidisy/bmp-backend:latest
            docker logout
          '''
        }
      }
    }
  }

  post {
    always {
      cleanWs()
    }
  }
}

